# ============================================================
# CodeTrack - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# .env.local is gitignored and will never be committed.
# ============================================================

# ---------------------------
# MongoDB (REQUIRED)
# ---------------------------
# Get a free cluster at https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/codetrack

# ---------------------------
# Auth (REQUIRED)
# ---------------------------
# Any long random string — used to sign session tokens.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=replace_with_a_long_random_secret_string

# Base URL of the app (keep as-is for local dev)
NEXTAUTH_URL=http://localhost:3000

# ---------------------------
# Platform API Keys (OPTIONAL)
# ---------------------------
# Only needed for fetching live stats from these platforms.
# The app works without them — it just won't pull live data.

# GitHub personal access token (https://github.com/settings/tokens)
GITHUB_TOKEN=

# LeetCode session cookie (from browser DevTools → Application → Cookies)
LEETCODE_SESSION=
